{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FaceRay",
  "version": "0.1.0",
  "identifier": "com.faceray.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FaceRay",
        "width": 420,
        "height": 660,
        "minWidth": 360,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Real-time AI virtual camera control panel.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/faceray_backend"],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
